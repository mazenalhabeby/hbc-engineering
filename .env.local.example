# ========================================
# HBC Application Environment Variables
# ========================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# ----------------------------------------
# SMTP Email Configuration (MXroute)
# ----------------------------------------
# MXroute SMTP server hostname
# Common values: mxlogin.com, mxroute.com, or your specific server
SMTP_HOST=heracles.mxrouting.net

# SMTP port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# Use SSL/TLS (true for port 465, false for port 587)
SMTP_SECURE=false

# Your MXroute email address (full email)
SMTP_USER=a.dessouky@hbc-engineering.com

# Your email account password
SMTP_PASSWORD=uBTa7vxVt83QfpAEc2ut

# "From" address for outgoing emails - Careers/Job Applications
SMTP_FROM="HBC Careers" <careers@yourdomain.com>

# "From" address for contact form emails
SMTP_FROM_CONTACT="HBC Group" <office@hbc-engineering.com>

# Email address where job applications will be sent
APPLICATION_RECIPIENT_EMAIL=amd07dev@gmail.com

# Email address where contact form submissions will be sent
CONTACT_RECIPIENT_EMAIL=amd07dev@gmail.com

# Email address where corporate/meeting requests will be sent
CORPORATE_RECIPIENT_EMAIL=amd07dev@gmail.com

# Email address for office inquiries (used in auto-reply emails)
OFFICE_EMAIL=amd07dev@gmail.com

# Email address for careers inquiries
CAREERS_EMAIL=careers@hbc-engineering.com

# Email address where newsletter subscriptions will be sent
NEWSLETTER_RECIPIENT_EMAIL=amd07dev@gmail.com
